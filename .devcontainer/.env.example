# Claude Code (Vertex AI auth)
CLAUDE_CODE_USE_VERTEX=1
ANTHROPIC_VERTEX_PROJECT_ID=
CLOUD_ML_REGION=global

# Sippy data mode: seed (default) or prod-like (BigQuery + prodlike DB)
SIPPY_DATA_MODE=seed

# BigQuery / GCS service account JSON (repo root; same default as devcontainer.json)
SIPPY_BIGQUERY_CREDENTIALS_FILE=/workspace/sippy-bigquery-job-importer-key.json
# Alternative: GOOGLE_APPLICATION_CREDENTIALS=/workspace/sippy-bigquery-job-importer-key.json
