{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-c",
        "npx @playwright/mcp@0.0.75 --viewport-size 1440,900 ${CHROME_PATH:+--executable-path \"$CHROME_PATH\"}"
      ]
    },
    "sippy-dev": {
      "type": "stdio",
      "command": "mcp/run.sh",
      "args": []
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    }
  }
}
